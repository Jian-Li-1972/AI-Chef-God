    "@types/express": "^5.0.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.0",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  }
}